# =============================================================================
# Color-by-Number — environment variable reference
# =============================================================================
# Copy the relevant section into each service's own .env file,
# or set these variables in your deployment dashboard (e.g. Render).
#
# Detailed descriptions are also in README.md.
# =============================================================================


# -----------------------------------------------------------------------------
# PIPELINE SERVICE  (pipeline/.env)
# -----------------------------------------------------------------------------

# [Required] Shared secret — must match PIPELINE_API_KEY in the backend.
# Generate with: openssl rand -hex 32
PIPELINE_API_KEY=change-me-to-a-strong-random-secret

# [Optional] Number of jobs that can run concurrently (thread pool size).
MAX_WORKERS=1

# [Optional] Seconds before a completed job is evicted from memory.
JOB_TTL_SECONDS=300

# [Optional] Maximum accepted upload size in bytes (default: 10 MB).
MAX_IMAGE_BYTES=10485760

# [Optional] Minimum image dimension in pixels (width AND height).
MIN_IMAGE_PX=100

# [Optional] Maximum image dimension in either direction.
MAX_IMAGE_PX=8000


# -----------------------------------------------------------------------------
# BACKEND SERVICE  (backend/.env)
# -----------------------------------------------------------------------------

# [Required] Base URL of the pipeline service (no trailing slash).
# Local dev example:  http://localhost:8001
# Render example:     https://colorbynumber-pipeline.onrender.com
PIPELINE_URL=http://localhost:8001

# [Required] Must match PIPELINE_API_KEY set in the pipeline service.
PIPELINE_API_KEY=change-me-to-a-strong-random-secret

# [Required] Secret used to sign anonymous session JWTs.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-different-strong-random-secret

# [Optional] Session token lifetime in seconds (default: 30 minutes).
SESSION_TTL_SECONDS=1800

# [Optional] Max job submissions per IP per rate-limit window.
RATE_LIMIT_JOBS=5

# [Optional] Sliding rate-limit window in seconds (default: 10 minutes).
RATE_LIMIT_WINDOW_SECONDS=600

# [Optional] Comma-separated allowed CORS origins.
# Use * during development; restrict to your frontend URL in production.
# Example: https://my-app.vercel.app
ALLOW_ORIGINS=*
