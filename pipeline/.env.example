# Pipeline service environment variables
# Copy to .env: cp .env.example .env

# [Required] Shared secret — must match PIPELINE_API_KEY in the backend.
# Generate with: openssl rand -hex 32
PIPELINE_API_KEY=change-me-to-a-strong-random-secret

# [Optional] Number of jobs that can run concurrently (thread pool size).
MAX_WORKERS=1

# [Optional] Seconds before a completed job is evicted from memory.
JOB_TTL_SECONDS=300

# [Optional] Maximum accepted upload size in bytes (default: 10 MB).
MAX_IMAGE_BYTES=10485760

# [Optional] Minimum image dimension in pixels (width AND height).
MIN_IMAGE_PX=100

# [Optional] Maximum image dimension in either direction.
MAX_IMAGE_PX=8000
