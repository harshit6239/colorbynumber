# ── FRONTEND SERVICE  (frontend/)
# ─────────────────────────────────────────────────────────────────
# Vite exposes only variables prefixed with VITE_ to client-side code.
#
# Set this to your deployed backend URL (no trailing slash).
# When omitted, the Vite dev-server proxy forwards requests to
# http://localhost:8001 automatically.
VITE_BACKEND_URL=https://your-backend.onrender.com
