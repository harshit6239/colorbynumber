# Backend service environment variables
# Copy to .env: cp .env.example .env

# [Required] Base URL of the pipeline service (no trailing slash).
# Local dev:  http://localhost:8001
# Render:     https://colorbynumber-pipeline.onrender.com
PIPELINE_URL=http://localhost:8001

# [Required] Must match PIPELINE_API_KEY set in the pipeline service.
PIPELINE_API_KEY=change-me-to-a-strong-random-secret

# [Required] Secret used to sign anonymous session JWTs.
# Generate with: openssl rand -hex 32  (use a DIFFERENT value from PIPELINE_API_KEY)
JWT_SECRET=change-me-to-a-different-strong-random-secret

# [Optional] Session token lifetime in seconds (default: 30 minutes).
SESSION_TTL_SECONDS=1800

# [Optional] Max job submissions per IP per rate-limit window.
RATE_LIMIT_JOBS=5

# [Optional] Sliding rate-limit window in seconds (default: 10 minutes).
RATE_LIMIT_WINDOW_SECONDS=600

# [Optional] Comma-separated allowed CORS origins.
# Use * during development; restrict to your frontend URL in production.
# Example: https://my-app.vercel.app
ALLOW_ORIGINS=*
